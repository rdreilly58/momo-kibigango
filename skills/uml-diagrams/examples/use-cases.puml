@startuml ReillyDesignStudio Use Cases

left to right direction

actor Client
actor Admin
actor Stripe as "Stripe System"

rectangle "ReillyDesignStudio" {
  usecase (Browse Portfolio) as browse
  usecase (View Project Details) as details
  usecase (Request Quote) as quote
  usecase (Purchase Digital Asset) as purchase
  usecase (Make Payment) as payment
  
  usecase (Manage Projects) as manage
  usecase (Generate Invoice) as invoice
  usecase (View Analytics) as analytics
  usecase (Manage Users) as users
}

Client --> browse
Client --> details
Client --> quote
Client --> purchase
Client --> payment

Admin --> manage
Admin --> invoice
Admin --> analytics
Admin --> users

payment --> Stripe

@enduml

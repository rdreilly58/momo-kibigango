#!/bin/bash
# uml — Unified UML diagram generator (Mermaid + PlantUML)
#
# Usage:
#   uml generate class diagram.mmd
#   uml generate db-schema diagram.puml
#   uml list
#   uml help

set -euo pipefail

COMMAND="${1:-help}"
DIAGRAM_TYPE="${2:-}"
DIAGRAM_FILE="${3:-}"

show_help() {
  cat << 'EOF'
🎨 UML Diagram Generator (Mermaid + PlantUML)

USAGE:
  uml generate <type> <file>    Generate diagram
  uml new <type> <name>         Create new diagram template
  uml list                       List diagram examples
  uml help                       Show this help

MERMAID DIAGRAM TYPES:
  • class                        Class diagrams (OOP)
  • sequence                     Sequence diagrams (interactions)
  • state                        State diagrams (state machines)
  • er                          Entity-relationship (databases)
  • deployment                   Deployment diagrams (architecture)
  • flowchart                    Flowcharts
  • gantt                        Gantt charts (timelines)

PLANTUML DIAGRAM TYPES:
  • component                    Component diagrams
  • deployment-adv               Advanced deployment
  • timing                       Timing diagrams
  • use-case                     Use case diagrams
  • activity                     Activity diagrams
  • object                       Object diagrams

EXAMPLES:
  # Generate from existing file
  uml generate state auth.mmd
  uml generate component system.puml

  # Create new diagram from template
  uml new sequence api-flow
  uml new class domain-model

  # List all examples
  uml list

FORMATS:
  .mmd    → Mermaid syntax (simple, readable)
  .puml   → PlantUML syntax (detailed, complex)
EOF
}

list_examples() {
  echo "📂 Available Examples:"
  echo ""
  echo "Mermaid (.mmd):"
  ls -1 ~/.openclaw/workspace/skills/uml-diagrams/examples/*.mmd 2>/dev/null | \
    xargs -I {} basename {} .mmd | sed 's/^/  • /'
  echo ""
  echo "PlantUML (.puml):"
  ls -1 ~/.openclaw/workspace/skills/uml-diagrams/examples/*.puml 2>/dev/null | \
    xargs -I {} basename {} .puml | sed 's/^/  • /'
}

create_template() {
  local TYPE="$1"
  local NAME="$2"
  local OUTPUT="${NAME}.mmd"

  case "$TYPE" in
    class)
      cat > "$OUTPUT" << 'TEMPLATE'
classDiagram
    class MyClass {
        +field: String
        +method()
    }
    
    class DependentClass {
        +dependency: MyClass
    }
    
    MyClass <|-- DependentClass
TEMPLATE
      ;;
    sequence)
      cat > "$OUTPUT" << 'TEMPLATE'
sequenceDiagram
    actor A
    participant B
    
    A ->> B: Request
    B -->> A: Response
TEMPLATE
      ;;
    state)
      cat > "$OUTPUT" << 'TEMPLATE'
stateDiagram-v2
    [*] --> Initial
    Initial --> Active: start
    Active --> Done: finish
    Done --> [*]
TEMPLATE
      ;;
    er)
      cat > "$OUTPUT" << 'TEMPLATE'
erDiagram
    ENTITY_A ||--o{ ENTITY_B : relationship
    
    ENTITY_A {
        string id PK
        string name
    }
    
    ENTITY_B {
        string id PK
        string entity_a_id FK
    }
TEMPLATE
      ;;
    *)
      echo "❌ Unknown type: $TYPE"
      echo "Try: class, sequence, state, er"
      exit 1
      ;;
  esac

  echo "✅ Created: $OUTPUT"
  echo "📝 Edit and run: uml generate $TYPE $OUTPUT"
}

generate_diagram() {
  local TYPE="$1"
  local FILE="$2"

  if [[ ! -f "$FILE" ]]; then
    echo "❌ File not found: $FILE"
    exit 1
  fi

  local EXT="${FILE##*.}"
  local BASENAME="${FILE%.*}"
  local OUTPUT="${BASENAME}.svg"

  case "$EXT" in
    mmd)
      echo "🎨 Generating Mermaid diagram: $FILE"
      mermaid "$FILE" -o "$OUTPUT" 2>/dev/null || {
        echo "❌ Mermaid generation failed"
        exit 1
      }
      ;;
    puml)
      echo "🎨 Generating PlantUML diagram: $FILE"
      plantuml -Tsvg "$FILE" -o "$(dirname "$FILE")" 2>/dev/null || {
        echo "❌ PlantUML generation failed"
        exit 1
      }
      OUTPUT="${BASENAME}.svg"
      ;;
    *)
      echo "❌ Unknown format: .$EXT (use .mmd or .puml)"
      exit 1
      ;;
  esac

  echo "✅ Generated: $OUTPUT"
  
  if command -v open &>/dev/null; then
    open "$OUTPUT"
    echo "📖 Opened in default viewer"
  fi
}

case "$COMMAND" in
  generate)
    generate_diagram "$DIAGRAM_TYPE" "$DIAGRAM_FILE"
    ;;
  new)
    create_template "$DIAGRAM_TYPE" "$DIAGRAM_FILE"
    ;;
  list)
    list_examples
    ;;
  help|--help|-h)
    show_help
    ;;
  *)
    echo "❌ Unknown command: $COMMAND"
    echo ""
    show_help
    exit 1
    ;;
esac

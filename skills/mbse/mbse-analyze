#!/usr/bin/env python3
# mbse-analyze — MBSE model analysis tool (Python version)
# Provides better YAML parsing and detailed analysis

import sys
import json
from pathlib import Path

try:
    import yaml
except ImportError:
    print("❌ PyYAML not installed. Install with: pip3 install pyyaml")
    sys.exit(1)

def load_model(model_path):
    """Load YAML model file"""
    path = Path(model_path)
    if not path.exists():
        print(f"❌ Model not found: {model_path}")
        sys.exit(1)
    
    with open(path, 'r') as f:
        return yaml.safe_load(f)

def analyze_model(model):
    """Analyze model and return statistics"""
    stats = {
        'system_name': model.get('system', {}).get('name', 'Unknown'),
        'system_version': model.get('system', {}).get('version', '?'),
        'system_status': model.get('system', {}).get('status', 'unknown'),
        'requirements_total': len(model.get('requirements', [])),
        'requirements_by_status': {},
        'requirements_by_priority': {},
        'architecture_components': len(model.get('architecture', {}).get('components', [])),
        'architecture_interactions': len(model.get('architecture', {}).get('interactions', [])),
        'tests_total': len(model.get('tests', [])),
        'tests_by_status': {},
        'behaviors': len(model.get('behaviors', [])),
        'risks': len(model.get('risks', [])),
        'risks_by_status': {},
        'decisions': len(model.get('decisions', [])),
    }
    
    # Analyze requirements
    for req in model.get('requirements', []):
        status = req.get('status', 'unknown')
        stats['requirements_by_status'][status] = stats['requirements_by_status'].get(status, 0) + 1
        
        priority = req.get('priority', 'unknown')
        stats['requirements_by_priority'][priority] = stats['requirements_by_priority'].get(priority, 0) + 1
    
    # Analyze tests
    for test in model.get('tests', []):
        status = test.get('status', 'unknown')
        stats['tests_by_status'][status] = stats['tests_by_status'].get(status, 0) + 1
    
    # Analyze risks
    for risk in model.get('risks', []):
        status = risk.get('status', 'unknown')
        stats['risks_by_status'][status] = stats['risks_by_status'].get(status, 0) + 1
    
    return stats

def print_analysis(stats):
    """Print formatted analysis"""
    print("📊 MBSE Analysis Report")
    print("=======================\n")
    
    print(f"System: {stats['system_name']} (v{stats['system_version']})")
    print(f"Status: {stats['system_status']}\n")
    
    # Requirements
    print(f"📋 Requirements: {stats['requirements_total']} total")
    for status, count in stats['requirements_by_status'].items():
        print(f"   - {status}: {count}")
    print(f"   By priority:")
    for priority, count in sorted(stats['requirements_by_priority'].items()):
        print(f"   - {priority}: {count}")
    print()
    
    # Architecture
    print(f"🏗️  Architecture:")
    print(f"   - Components: {stats['architecture_components']}")
    print(f"   - Interactions: {stats['architecture_interactions']}")
    print()
    
    # Behaviors
    if stats['behaviors'] > 0:
        print(f"🔄 Behaviors: {stats['behaviors']}")
        print()
    
    # Tests
    print(f"✅ Tests: {stats['tests_total']} total")
    for status, count in stats['tests_by_status'].items():
        print(f"   - {status}: {count}")
    print()
    
    # Risks
    if stats['risks'] > 0:
        print(f"⚠️  Risks: {stats['risks']} total")
        for status, count in stats['risks_by_status'].items():
            print(f"   - {status}: {count}")
        print()
    
    # Decisions
    if stats['decisions'] > 0:
        print(f"📌 Architecture Decisions: {stats['decisions']}\n")
    
    # Recommendations
    print("📊 Next Steps:")
    print("- Trace requirements: mbse trace model.yaml")
    print("- Check coverage: mbse coverage model.yaml")
    print("- View risks: mbse risks model.yaml")
    print("- Generate RTM: mbse matrix model.yaml")
    print()
    print("✅ Analysis complete")

def main():
    if len(sys.argv) < 2:
        print("Usage: mbse-analyze <model.yaml>")
        sys.exit(1)
    
    model_path = sys.argv[1]
    model = load_model(model_path)
    stats = analyze_model(model)
    print_analysis(stats)

if __name__ == '__main__':
    main()

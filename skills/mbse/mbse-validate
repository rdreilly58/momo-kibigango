#!/usr/bin/env python3
"""
mbse-validate — Validate MBSE YAML models
Checks for required sections, valid IDs, and structural integrity
"""

import sys
from pathlib import Path

try:
    import yaml
except ImportError:
    print("❌ PyYAML not installed")
    sys.exit(1)

def load_model(model_path):
    """Load and validate YAML structure"""
    path = Path(model_path)
    if not path.exists():
        print(f"❌ Model not found: {model_path}")
        return None
    
    try:
        with open(path, 'r') as f:
            return yaml.safe_load(f)
    except yaml.YAMLError as e:
        print(f"❌ YAML parsing error: {e}")
        return None

def validate_model(model, model_path):
    """Validate model structure"""
    
    errors = []
    warnings = []
    
    # Check required sections
    required_sections = ['system', 'requirements', 'architecture', 'tests']
    for section in required_sections:
        if section not in model:
            errors.append(f"Missing required section: '{section}'")
        else:
            print(f"  ✓ {section}: OK")
    
    if errors:
        return False, errors, warnings
    
    # Validate system
    system = model.get('system', {})
    if 'name' not in system:
        errors.append("system: Missing 'name'")
    
    # Validate requirements
    requirements = model.get('requirements', [])
    req_ids = set()
    for i, req in enumerate(requirements):
        if 'id' not in req:
            errors.append(f"requirements[{i}]: Missing 'id'")
        else:
            req_id = req['id']
            req_ids.add(req_id)
            
            if 'status' not in req:
                errors.append(f"{req_id}: Missing 'status'")
            
            if 'priority' not in req:
                warnings.append(f"{req_id}: Missing 'priority'")
            
            if 'title' not in req:
                errors.append(f"{req_id}: Missing 'title'")
    
    # Validate architecture
    architecture = model.get('architecture', {})
    components = architecture.get('components', [])
    comp_ids = set()
    
    for i, comp in enumerate(components):
        if 'id' not in comp:
            errors.append(f"architecture.components[{i}]: Missing 'id'")
        else:
            comp_ids.add(comp['id'])
            
            if 'name' not in comp:
                errors.append(f"{comp['id']}: Missing 'name'")
            
            # Validate traces_to references
            for traced_id in comp.get('realizes', []):
                if traced_id not in req_ids:
                    warnings.append(f"{comp['id']}: References unknown requirement '{traced_id}'")
    
    # Validate tests
    tests = model.get('tests', [])
    test_ids = set()
    
    for i, test in enumerate(tests):
        if 'id' not in test:
            errors.append(f"tests[{i}]: Missing 'id'")
        else:
            test_id = test['id']
            test_ids.add(test_id)
            
            if 'verifies' not in test or not test['verifies']:
                warnings.append(f"{test_id}: Missing 'verifies' (requirement references)")
            else:
                # Check references
                for req_ref in test.get('verifies', []):
                    if req_ref not in req_ids:
                        errors.append(f"{test_id}: References unknown requirement '{req_ref}'")
            
            if 'status' not in test:
                errors.append(f"{test_id}: Missing 'status'")
    
    # Validate risks
    risks = model.get('risks', [])
    for i, risk in enumerate(risks):
        if 'id' not in risk:
            errors.append(f"risks[{i}]: Missing 'id'")
    
    # Validate decisions
    decisions = model.get('decisions', [])
    for i, decision in enumerate(decisions):
        if 'id' not in decision:
            errors.append(f"decisions[{i}]: Missing 'id'")
    
    success = len(errors) == 0
    return success, errors, warnings

def print_validation_result(model_path, success, errors, warnings):
    """Print validation results"""
    
    print(f"\n{'='*80}")
    print(f"🔍 MBSE Validation: {model_path}")
    print(f"{'='*80}\n")
    
    if errors:
        print(f"❌ {len(errors)} Error(s):")
        for error in errors:
            print(f"   • {error}")
        print()
    
    if warnings:
        print(f"⚠️  {len(warnings)} Warning(s):")
        for warning in warnings:
            print(f"   • {warning}")
        print()
    
    if success:
        print("✅ Validation passed!")
    else:
        print("❌ Validation failed!")
    
    print(f"{'='*80}\n")
    
    return success

def main():
    if len(sys.argv) < 2:
        print("Usage: mbse-validate <model.yaml> [model2.yaml ...]")
        print("\nValidates MBSE models for:")
        print("  • Required sections (system, requirements, architecture, tests)")
        print("  • Valid IDs and references")
        print("  • Structural integrity")
        sys.exit(1)
    
    all_valid = True
    
    for model_path in sys.argv[1:]:
        model = load_model(model_path)
        if not model:
            all_valid = False
            continue
        
        success, errors, warnings = validate_model(model, model_path)
        result_valid = print_validation_result(model_path, success, errors, warnings)
        
        if not result_valid:
            all_valid = False
    
    sys.exit(0 if all_valid else 1)

if __name__ == '__main__':
    main()

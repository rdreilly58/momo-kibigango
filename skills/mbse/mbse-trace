#!/usr/bin/env python3
"""
mbse-trace — Requirement Traceability Tool
Shows requirement→architecture→test chains and identifies gaps
"""

import sys
import json
from pathlib import Path
from collections import defaultdict

try:
    import yaml
except ImportError:
    print("❌ PyYAML not installed. Install with: pip3 install pyyaml")
    sys.exit(1)

def load_model(model_path):
    """Load YAML model"""
    path = Path(model_path)
    if not path.exists():
        print(f"❌ Model not found: {model_path}")
        sys.exit(1)
    
    with open(path, 'r') as f:
        return yaml.safe_load(f)

def trace_requirements(model, output_format="table"):
    """Trace requirements through architecture to tests"""
    
    requirements = {r['id']: r for r in model.get('requirements', [])}
    architecture = {c['id']: c for c in model.get('architecture', {}).get('components', [])}
    tests = {t['id']: t for t in model.get('tests', [])}
    
    # Build traceability map
    traces = defaultdict(lambda: {'architecture': [], 'tests': []})
    
    for req_id, req in requirements.items():
        # Find architecture components this requirement traces to
        for arch_id in req.get('traces_to', []):
            if arch_id in architecture or arch_id.startswith('ARCH'):
                traces[req_id]['architecture'].append(arch_id)
        
        # Find tests that verify this requirement
        for test_id, test in tests.items():
            if req_id in test.get('verifies', []):
                traces[req_id]['tests'].append(test_id)
    
    if output_format == "json":
        output_json(requirements, traces, architecture, tests)
    elif output_format == "csv":
        output_csv(requirements, traces)
    else:
        output_table(requirements, traces, architecture, tests)

def output_table(requirements, traces, architecture, tests):
    """Output as formatted table"""
    print("\n🔗 Requirement Traceability")
    print("=" * 100)
    
    for req_id in sorted(requirements.keys()):
        req = requirements[req_id]
        trace = traces[req_id]
        
        print(f"\n📌 {req_id} — {req.get('title', 'Untitled')}")
        print(f"   Status: {req.get('status', '?')} | Priority: {req.get('priority', '?')}")
        
        # Architecture traces
        if trace['architecture']:
            print(f"   Architecture Components:")
            for arch_id in trace['architecture']:
                print(f"     → {arch_id}")
        else:
            print(f"   ⚠️  Architecture: NOT TRACED")
        
        # Test traces
        if trace['tests']:
            print(f"   Verification Tests:")
            for test_id in trace['tests']:
                test = tests[test_id]
                status = test.get('status', '?')
                coverage = test.get('coverage_percentage', 0)
                print(f"     ✓ {test_id} ({status}, {coverage}% coverage)")
        else:
            print(f"   ⚠️  Tests: NO TESTS FOUND")
    
    # Summary
    print("\n" + "=" * 100)
    print("📊 Traceability Summary")
    total_reqs = len(requirements)
    traced_arch = sum(1 for t in traces.values() if t['architecture'])
    tested = sum(1 for t in traces.values() if t['tests'])
    
    print(f"   Total Requirements: {total_reqs}")
    print(f"   With Architecture: {traced_arch} ({100*traced_arch//total_reqs if total_reqs else 0}%)")
    print(f"   With Tests: {tested} ({100*tested//total_reqs if total_reqs else 0}%)")
    
    # Gaps
    untraced = [req_id for req_id, t in traces.items() if not t['architecture']]
    untested = [req_id for req_id, t in traces.items() if not t['tests']]
    
    if untraced:
        print(f"\n⚠️  GAPS - Untraced Requirements:")
        for req_id in untraced:
            print(f"   - {req_id} ({requirements[req_id].get('title', 'N/A')})")
    
    if untested:
        print(f"\n⚠️  GAPS - Untested Requirements:")
        for req_id in untested:
            print(f"   - {req_id} ({requirements[req_id].get('title', 'N/A')})")
    
    print()

def output_csv(requirements, traces):
    """Output as CSV"""
    print("REQ_ID,Title,Status,Priority,Architecture_Count,Tests_Count,Traced,Tested")
    for req_id in sorted(requirements.keys()):
        req = requirements[req_id]
        trace = traces[req_id]
        arch_count = len(trace['architecture'])
        test_count = len(trace['tests'])
        traced = "Yes" if arch_count > 0 else "No"
        tested = "Yes" if test_count > 0 else "No"
        
        title = req.get('title', '').replace('"', '""')
        print(f'"{req_id}","{title}","{req.get("status", "")}","{req.get("priority", "")}",{arch_count},{test_count},{traced},{tested}')

def output_json(requirements, traces, architecture, tests):
    """Output as JSON"""
    result = {
        'traceability': {},
        'summary': {
            'total_requirements': len(requirements),
            'with_architecture': sum(1 for t in traces.values() if t['architecture']),
            'with_tests': sum(1 for t in traces.values() if t['tests'])
        }
    }
    
    for req_id in sorted(requirements.keys()):
        req = requirements[req_id]
        trace = traces[req_id]
        result['traceability'][req_id] = {
            'title': req.get('title'),
            'status': req.get('status'),
            'priority': req.get('priority'),
            'architecture': trace['architecture'],
            'tests': trace['tests']
        }
    
    print(json.dumps(result, indent=2))

def main():
    if len(sys.argv) < 2:
        print("Usage: mbse-trace <model.yaml> [--format json|csv|table]")
        print("\nFormats:")
        print("  table (default) — Human-readable table")
        print("  csv             — Comma-separated values")
        print("  json            — JSON format")
        sys.exit(1)
    
    model_path = sys.argv[1]
    output_format = "table"
    
    if "--format" in sys.argv:
        idx = sys.argv.index("--format")
        if idx + 1 < len(sys.argv):
            output_format = sys.argv[idx + 1]
    
    model = load_model(model_path)
    trace_requirements(model, output_format)

if __name__ == '__main__':
    main()

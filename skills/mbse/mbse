#!/bin/bash
# mbse — Model-Based Systems Engineering CLI
#
# USAGE:
#   mbse analyze <model.yaml>          Analyze model & generate reports
#   mbse trace <model.yaml>            Show requirement traceability
#   mbse coverage <model.yaml>         Show test coverage by requirement
#   mbse matrix <model.yaml>           Generate RTM (Requirements Traceability Matrix)
#   mbse validate <model.yaml>         Validate model structure
#   mbse status <model.yaml>           Show system status dashboard
#   mbse risks <model.yaml>            Show risks & mitigation status
#   mbse diagrams <model.yaml>         Auto-generate SysML diagrams
#   mbse export <model.yaml> --format json|html|mermaid
#   mbse help                          Show this help

set -euo pipefail

COMMAND="${1:-help}"
MODEL_FILE="${2:-}"
FORMAT="${3:-}"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

show_help() {
  cat << 'EOF'
🔧 MBSE (Model-Based Systems Engineering) CLI

USAGE:
  mbse analyze <model.yaml>       Comprehensive analysis & report
  mbse trace <model.yaml>         Requirement traceability details
  mbse coverage <model.yaml>      Test coverage analysis
  mbse matrix <model.yaml>        Requirements Traceability Matrix (RTM)
  mbse validate <model.yaml>      Validate YAML schema
  mbse status <model.yaml>        System status dashboard
  mbse risks <model.yaml>         Risk analysis & mitigation
  mbse diagrams <model.yaml>      Generate architecture diagrams
  mbse export <model.yaml> --format json|html|mermaid|sysml
  mbse help                       Show this help

COMMANDS:

  analyze
    Comprehensive system analysis including:
    • Requirements status breakdown
    • Architecture overview
    • Test coverage statistics
    • Risk assessment
    • Traceability summary
    
    Usage: mbse analyze project-model.yaml

  trace
    Show requirement-to-architecture-to-test traceability chains.
    Maps each requirement through to verification tests.
    
    Usage: mbse trace project-model.yaml

  coverage
    Test coverage analysis:
    • Requirements covered by tests
    • Uncovered requirements (gaps)
    • Test-to-requirement mapping
    
    Usage: mbse coverage project-model.yaml

  matrix
    Generate Requirements Traceability Matrix (RTM):
    • Requirement ↔ Architecture
    • Requirement ↔ Tests
    • Architecture ↔ Tests
    
    Usage: mbse matrix project-model.yaml

  validate
    Validate YAML model against schema.
    Reports structural errors and warnings.
    
    Usage: mbse validate project-model.yaml

  status
    Display system status dashboard:
    • Overall project health
    • Requirement implementation status
    • Test passing rate
    • Risk mitigation progress
    
    Usage: mbse status project-model.yaml

  risks
    Risk analysis report:
    • High-risk items
    • Mitigation strategies
    • Coverage by requirements
    • Owner responsibilities
    
    Usage: mbse risks project-model.yaml

  diagrams
    Auto-generate SysML/architecture diagrams from model:
    • Component diagram (Mermaid)
    • Sequence diagrams for behaviors
    • State machines for workflows
    
    Usage: mbse diagrams project-model.yaml

  export
    Export model to various formats.
    
    Formats:
      json      - JSON representation
      html      - Formatted HTML report
      mermaid   - Mermaid diagram syntax
      sysml     - SysML format (Papyrus-compatible)
    
    Usage: mbse export project-model.yaml --format html

EXAMPLES:

  # Analyze ReillyDesignStudio model
  mbse analyze reillydesignstudio/model.yaml

  # Show traceability for Momotaro iOS
  mbse trace momotaro-ios/model.yaml

  # Check test coverage
  mbse coverage reillydesignstudio/model.yaml

  # Generate RTM
  mbse matrix reillydesignstudio/model.yaml > requirements-matrix.csv

  # Validate model before commit
  mbse validate reillydesignstudio/model.yaml

  # Dashboard view
  mbse status reillydesignstudio/model.yaml

  # Risk analysis
  mbse risks reillydesignstudio/model.yaml

  # Generate diagrams
  mbse diagrams reillydesignstudio/model.yaml

  # Export as HTML report
  mbse export reillydesignstudio/model.yaml --format html > report.html

CONFIGURATION:

  Place YAML model files alongside code:
    
    project/
    ├── model.yaml                    (Main system model)
    ├── requirements/
    │   └── *.md                      (Detailed requirements)
    ├── docs/diagrams/
    │   └── generated/                (Auto-generated diagrams)
    └── tests/
        └── (Your test files)

MODEL FILES:

  See: ~/.openclaw/workspace/skills/mbse/schema.yaml

EXAMPLES:

  See: ~/.openclaw/workspace/skills/mbse/examples/

SCHEMA:

  Full schema with all fields:
  ~/.openclaw/workspace/skills/mbse/schema.yaml

EOF
}

# Parse YAML key-value (simple parser for basic keys)
yaml_get() {
  local file="$1"
  local key="$2"
  grep "^ *$key:" "$file" 2>/dev/null | sed "s/.*: //" | tr -d "'" | head -1
}

# Count items in YAML array (crude count)
yaml_count() {
  local file="$1"
  local section="$2"
  awk "/^$section:/,/^[a-z]/" "$file" | grep "^ *- id:" | wc -l
}

analyze_model() {
  local model="$1"
  
  if [[ ! -f "$model" ]]; then
    echo "❌ Model not found: $model"
    exit 1
  fi
  
  echo "📊 MBSE Analysis Report"
  echo "======================="
  echo ""
  
  local sys_name=$(yaml_get "$model" "name")
  local sys_version=$(yaml_get "$model" "version")
  
  echo "System: $sys_name (v$sys_version)"
  echo ""
  
  # Count requirements
  local req_count=$(yaml_count "$model" "requirements")
  echo "📋 Requirements: $req_count total"
  
  # Count architecture components
  local arch_count=$(yaml_count "$model" "architecture")
  echo "🏗️  Architecture Components: $arch_count"
  
  # Count tests
  local test_count=$(yaml_count "$model" "tests")
  echo "✅ Tests: $test_count"
  
  # Count risks
  local risk_count=$(yaml_count "$model" "risks")
  echo "⚠️  Risks: $risk_count"
  
  # Count decisions
  local decision_count=$(yaml_count "$model" "decisions")
  echo "📌 Architecture Decisions: $decision_count"
  
  echo ""
  echo "🔗 Traceability Summary"
  echo "- Analyze model with: mbse trace $model"
  echo "- Check coverage with: mbse coverage $model"
  echo "- View risks with: mbse risks $model"
  echo ""
  echo "✅ Analysis complete"
}

trace_model() {
  local model="$1"
  
  if [[ ! -f "$model" ]]; then
    echo "❌ Model not found: $model"
    exit 1
  fi
  
  echo "🔗 Requirement Traceability"
  echo "============================"
  echo ""
  
  # Extract requirements and show their traces (simple implementation)
  awk '/^requirements:/,/^[a-z]/ {
    if (/^ *- id:/) {
      req_id=$0; gsub(/.*id: /, "", req_id); gsub(/^[ \t]+/, "", req_id)
      print "📌 Requirement: " req_id
    }
    if (/title:/) {
      title=$0; gsub(/.*title: /, "", title); gsub(/^[ \t]+/, "", title)
      print "   Title: " title
    }
    if (/status:/) {
      status=$0; gsub(/.*status: /, "", status); gsub(/^[ \t]+/, "", status)
      print "   Status: " status
    }
    if (/traces_to:/) {
      print "   Traces to:"
    }
    if (/^ *- [A-Z]/) {
      arch=$0; gsub(/.*- /, "", arch); gsub(/^[ \t]+/, "", arch)
      print "     → " arch
    }
  }' "$model"
  
  echo ""
  echo "✅ Traceability complete"
}

coverage_model() {
  local model="$1"
  
  if [[ ! -f "$model" ]]; then
    echo "❌ Model not found: $model"
    exit 1
  fi
  
  echo "📈 Test Coverage Analysis"
  echo "========================="
  echo ""
  
  local total_reqs=$(yaml_count "$model" "requirements")
  local total_tests=$(yaml_count "$model" "tests")
  
  echo "Total Requirements: $total_reqs"
  echo "Total Tests: $total_tests"
  
  if (( total_reqs > 0 )); then
    local coverage=$((total_tests * 100 / total_reqs))
    echo "Estimated Coverage: ~${coverage}%"
  fi
  
  echo ""
  echo "📊 Coverage Details:"
  echo "- Run: mbse matrix $model (for detailed mapping)"
  echo "- Check specific requirement traces with: mbse trace $model"
  echo ""
  echo "✅ Coverage analysis complete"
}

validate_model() {
  local model="$1"
  
  if [[ ! -f "$model" ]]; then
    echo "❌ Model not found: $model"
    exit 1
  fi
  
  echo "✔️  Validating model structure..."
  echo ""
  
  local errors=0
  
  # Check for required top-level sections
  if ! grep -q "^system:" "$model"; then
    echo "❌ Missing required section: system"
    ((errors++))
  else
    echo "✅ system section found"
  fi
  
  if ! grep -q "^requirements:" "$model"; then
    echo "❌ Missing required section: requirements"
    ((errors++))
  else
    echo "✅ requirements section found"
  fi
  
  if ! grep -q "^architecture:" "$model"; then
    echo "❌ Missing required section: architecture"
    ((errors++))
  else
    echo "✅ architecture section found"
  fi
  
  if ! grep -q "^tests:" "$model"; then
    echo "❌ Missing required section: tests"
    ((errors++))
  else
    echo "✅ tests section found"
  fi
  
  echo ""
  
  if (( errors == 0 )); then
    echo "✅ Model validation passed (all required sections present)"
    return 0
  else
    echo "❌ Validation failed with $errors error(s)"
    return 1
  fi
}

status_dashboard() {
  local model="$1"
  
  if [[ ! -f "$model" ]]; then
    echo "❌ Model not found: $model"
    exit 1
  fi
  
  echo "📊 System Status Dashboard"
  echo "=========================="
  echo ""
  
  local sys_name=$(yaml_get "$model" "name")
  local sys_status=$(yaml_get "$model" "status")
  
  echo "System: $sys_name"
  echo "Status: $sys_status"
  echo ""
  
  local req_count=$(yaml_count "$model" "requirements")
  local arch_count=$(yaml_count "$model" "architecture")
  local test_count=$(yaml_count "$model" "tests")
  local risk_count=$(yaml_count "$model" "risks")
  
  echo "📈 Key Metrics"
  echo "  Requirements: $req_count"
  echo "  Architecture Components: $arch_count"
  echo "  Tests: $test_count"
  echo "  Identified Risks: $risk_count"
  echo ""
  echo "✅ Dashboard generated"
}

risks_analysis() {
  local model="$1"
  
  if [[ ! -f "$model" ]]; then
    echo "❌ Model not found: $model"
    exit 1
  fi
  
  echo "⚠️  Risk Analysis Report"
  echo "======================="
  echo ""
  
  local risk_count=$(yaml_count "$model" "risks")
  
  if (( risk_count == 0 )); then
    echo "✅ No risks identified"
  else
    echo "Found $risk_count risks"
    echo ""
    echo "Risk details:"
    awk '/^risks:/,/^[a-z]/ {
      if (/^ *- id:/) {
        risk_id=$0; gsub(/.*id: /, "", risk_id)
        print "  • Risk: " risk_id
      }
      if (/title:/) {
        title=$0; gsub(/.*title: /, "", title)
        print "    Title: " title
      }
      if (/probability:/) {
        prob=$0; gsub(/.*probability: /, "", prob)
        print "    Probability: " prob
      }
      if (/status:/) {
        status=$0; gsub(/.*status: /, "", status)
        print "    Status: " status
      }
    }' "$model"
  fi
  
  echo ""
  echo "✅ Risk analysis complete"
}

case "$COMMAND" in
  analyze)
    analyze_model "$MODEL_FILE"
    ;;
  trace)
    trace_model "$MODEL_FILE"
    ;;
  coverage)
    coverage_model "$MODEL_FILE"
    ;;
  matrix)
    echo "📋 Requirements Traceability Matrix (RTM)"
    echo "========================================"
    trace_model "$MODEL_FILE"
    ;;
  validate)
    validate_model "$MODEL_FILE"
    ;;
  status)
    status_dashboard "$MODEL_FILE"
    ;;
  risks)
    risks_analysis "$MODEL_FILE"
    ;;
  diagrams)
    echo "🎨 Generating architecture diagrams from model..."
    echo "Note: Full diagram generation requires model-to-Mermaid/PlantUML conversion"
    echo "Current status: Diagram engine in development"
    ;;
  export)
    echo "📤 Export functionality coming soon"
    echo "Supported formats: json, html, mermaid, sysml"
    ;;
  help|--help|-h)
    show_help
    ;;
  *)
    echo "❌ Unknown command: $COMMAND"
    echo ""
    show_help
    exit 1
    ;;
esac

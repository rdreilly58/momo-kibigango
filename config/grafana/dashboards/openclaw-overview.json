{
  "id": null,
  "uid": "openclaw-overview",
  "title": "OpenClaw Overview",
  "tags": ["openclaw", "observability"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-2h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "job",
        "label": "Cron Job",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "openclaw-prometheus"},
        "query": {
          "query": "label_values(openclaw_cron_stale, job)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {},
        "sort": 1,
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Session Status",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "uid": "openclaw-prometheus", "type": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "ACTIVE", "color": "green" }, "1": { "text": "STALE", "color": "red" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        }
      },
      "targets": [{ "expr": "openclaw_session_stale", "legendFormat": "Session" }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Session Age",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "uid": "openclaw-prometheus", "type": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 2700 }, { "color": "red", "value": 3600 }] }
        }
      },
      "targets": [{ "expr": "openclaw_session_age_seconds", "legendFormat": "Session Age" }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Memory Entries",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "uid": "openclaw-prometheus", "type": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "targets": [{ "expr": "openclaw_memory_entries_total", "legendFormat": "Total Memories" }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Stale Crons",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "uid": "openclaw-prometheus", "type": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 3 }] }
        }
      },
      "targets": [{ "expr": "sum(openclaw_cron_stale)", "legendFormat": "Stale Crons" }]
    },
    {
      "id": 5,
      "type": "table",
      "title": "Cron Job Health",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 10 },
      "datasource": { "uid": "openclaw-prometheus", "type": "prometheus" },
      "options": { "footer": { "show": false } },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "stale" }, "properties": [{ "id": "custom.displayMode", "value": "color-background" }, { "id": "mappings", "value": [{ "type": "value", "options": { "0": { "text": "OK", "color": "green" }, "1": { "text": "STALE", "color": "red" } } }] }] },
          { "matcher": { "id": "byName", "options": "exit_code" }, "properties": [{ "id": "custom.displayMode", "value": "color-background" }, { "id": "mappings", "value": [{ "type": "value", "options": { "0": { "text": "OK", "color": "green" } } }] }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } }] },
          { "matcher": { "id": "byName", "options": "age_seconds" }, "properties": [{ "id": "unit", "value": "s" }] }
        ]
      },
      "targets": [
        { "expr": "openclaw_cron_last_run_age_seconds{job=~\"$job\"}", "legendFormat": "{{job}}", "instant": true },
        { "expr": "openclaw_cron_last_exit_code{job=~\"$job\"}", "legendFormat": "{{job}}", "instant": true },
        { "expr": "openclaw_cron_stale{job=~\"$job\"}", "legendFormat": "{{job}}", "instant": true }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        { "id": "organize", "options": { "renameByName": { "openclaw_cron_last_run_age_seconds": "age_seconds", "openclaw_cron_last_exit_code": "exit_code", "openclaw_cron_stale": "stale", "job": "Job" } } }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Session Age Over Time",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
      "datasource": { "uid": "openclaw-prometheus", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 2700 }, { "color": "red", "value": 3600 }] }
        }
      },
      "targets": [{ "expr": "openclaw_session_age_seconds", "legendFormat": "Session Age" }]
    },
    {
      "id": 7,
      "type": "barchart",
      "title": "Memory Entries by Tier",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 8 },
      "datasource": { "uid": "openclaw-prometheus", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "stacking": { "mode": "normal" },
            "fillOpacity": 80,
            "lineWidth": 0
          }
        }
      },
      "options": {
        "barWidth": 0.97,
        "groupWidth": 0.7,
        "stacking": "normal",
        "fillOpacity": 80,
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" },
        "xField": "Time"
      },
      "targets": [{ "expr": "openclaw_memory_entries_by_tier", "legendFormat": "{{tier}}" }]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Log Errors (last 200 lines)",
      "gridPos": { "x": 0, "y": 22, "w": 24, "h": 8 },
      "datasource": { "uid": "openclaw-prometheus", "type": "prometheus" },
      "targets": [{ "expr": "openclaw_log_errors_recent", "legendFormat": "{{log}}" }]
    },
    {
      "id": 9,
      "title": "Session Context Age",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "openclaw-prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 30},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "openclaw-prometheus"},
          "expr": "openclaw_session_context_age_seconds",
          "legendFormat": "SESSION_CONTEXT.md age",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 3600},
              {"color": "red", "value": 14400}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 10,
      "title": "CPU Usage Over Time",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "openclaw-prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 34},
      "targets": [
        {
          "expr": "openclaw_system_cpu_percent",
          "legendFormat": "CPU %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": {"mode": "palette-classic"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 70},
              {"color": "red", "value": 90}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 11,
      "title": "Memory Usage Over Time",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "openclaw-prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 34},
      "targets": [
        {
          "expr": "openclaw_system_memory_percent",
          "legendFormat": "RAM %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": {"mode": "palette-classic"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 80},
              {"color": "red", "value": 90}
            ]
          }
        },
        "overrides": []
      }
    }
  ]
}

{
  "routing": {
    "classifier": {
      "enabled": true,
      "strategy": "hybrid",
      "description": "Hybrid classifier: keyword matching + length signals + code detection",
      "implementation": "scripts/task-classifier-v2.py",

      "simple_keywords": [
        "weather",
        "date",
        "time",
        "calendar",
        "schedule",
        "status",
        "check",
        "remind",
        "reminder",
        "heartbeat",
        "list",
        "what is",
        "what's",
        "what are",
        "is there",
        "how many",
        "how much",
        "current",
        "latest",
        "next",
        "today",
        "tomorrow",
        "this week",
        "search for",
        "ping",
        "hi",
        "hello"
      ],
      "simple_max_words": 50,
      "simple_max_tokens": 15,
      "simple_model": "anthropic/claude-haiku-4-6",

      "medium_model": "anthropic/claude-sonnet-4-6",

      "complex_keywords": [
        "refactor",
        "architecture",
        "algorithm",
        "migrate",
        "migration",
        "benchmark",
        "deploy",
        "audit",
        "redesign",
        "overhaul",
        "security review",
        "data migration",
        "system design",
        "design system",
        "infrastructure",
        "performance analysis"
      ],
      "complex_model": "anthropic/claude-opus-4-7",

      "override_signals": {
        "multiline_min_medium": true,
        "multiline_threshold_lines": 3,
        "long_message_min_medium": true,
        "long_message_threshold_words": 100,
        "code_block_min_medium": true
      },

      "context_simple": {
        "max_chars": 5000,
        "files": ["SOUL.md", "USER.md"]
      },
      "context_medium": {
        "max_chars": 40000,
        "files": ["SOUL.md", "USER.md", "MEMORY.md"]
      },
      "context_complex": {
        "max_chars": 135000,
        "files": ["SOUL.md", "USER.md", "MEMORY.md", "TOOLS.md"]
      },

      "word_count_min_medium": 50,
      "token_threshold": 50,
      "line_count_threshold": 3,

      "default_model": "anthropic/claude-sonnet-4-6",

      "rules": [
        {
          "pattern": "code|javascript|python|swift|java",
          "classification": "medium",
          "reason": "Code-related = Sonnet minimum, not Opus"
        },
        {
          "pattern": "simple|quick|fast|easy",
          "classification": "simple",
          "reason": "User hints simplicity"
        },
        {
          "pattern": "analyze|understand|explain|why",
          "classification": "medium",
          "reason": "Analysis = Sonnet; Opus only for explicit complex keywords"
        }
      ]
    }
  }
}

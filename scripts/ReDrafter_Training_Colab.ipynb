   "source": [
    "# ReDrafter Training — Qwen2.5-7B on Colab A100\n",
    "Apple ReDrafter (arxiv:2403.09919) — trains a small RNN draft head for speculative decoding.\n",
    "\n",
    "**Setup:** Runtime → Change runtime type → A100 GPU\n",
    "\n",
    "**Estimated time:** 2-3 hours for 3000 steps"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 1: Install dependencies\n",
    "!pip install -q transformers datasets accelerate bitsandbytes"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 2: Imports & config\n",
    "import os, gc, math, time, logging\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "import torch.nn.functional as F\n",
    "from torch.optim import AdamW\n",
    "from torch.utils.data import DataLoader, Dataset\n",
    "from transformers import AutoTokenizer, AutoModelForCausalLM\n",
    "from datasets import load_dataset\n",
    "\n",
    "logging.basicConfig(level=logging.INFO, format='%(asctime)s %(message)s')\n",
    "log = logging.getLogger()\n",
    "\n",
    "# Verify GPU\n",
    "device = torch.device('cuda')\n",
    "print(f'GPU: {torch.cuda.get_device_name(0)}')\n",
    "print(f'VRAM: {torch.cuda.get_device_properties(0).total_memory / 1e9:.1f} GB')\n",
    "\n",
    "# Config\n",
    "BASE_MODEL         = 'Qwen/Qwen2.5-7B-Instruct'\n",
    "DRAFTER_HIDDEN     = 512\n",
    "DRAFTER_LAYERS     = 2\n",
    "NUM_DRAFT_TOKENS   = 4\n",
    "MAX_SEQ_LEN        = 512      # Proven safe on A100 40GB\n",
    "MAX_SAMPLES        = 50_000\n",
    "BATCH_SIZE         = 8\n",
    "GRAD_ACCUM         = 4        # Effective batch = 32\n",
    "LEARNING_RATE      = 2e-4\n",
    "WEIGHT_DECAY       = 0.01\n",
    "WARMUP_STEPS       = 200\n",
    "MAX_STEPS          = 3000\n",
    "SAVE_EVERY         = 500\n",
    "LOG_EVERY          = 10\n",
    "OUTPUT_DIR         = '/content/drafter_output'\n",
    "os.makedirs(OUTPUT_DIR, exist_ok=True)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 3: ReDrafter head architecture\n",
    "class ReDrafterHead(nn.Module):\n",
    "    \"\"\"\n",
    "    Apple ReDrafter draft head (arxiv:2403.09919).\n",
    "    Takes last hidden state from frozen base model,\n",
    "    autoregressively proposes K draft tokens.\n",
    "    \"\"\"\n",
    "    def __init__(self, vocab_size, hidden_size, drafter_hidden=512,\n",
    "                 num_layers=2, num_draft_tokens=4):\n",
    "        super().__init__()\n",
    "        self.num_draft_tokens = num_draft_tokens\n",
    "        self.input_proj  = nn.Linear(hidden_size, drafter_hidden)\n",
    "        self.gru = nn.GRU(drafter_hidden, drafter_hidden,\n",
    "                          num_layers=num_layers, batch_first=True)\n",
    "        self.token_embed = nn.Embedding(vocab_size, drafter_hidden)\n",
    "        self.output_proj = nn.Linear(drafter_hidden, vocab_size, bias=False)\n",
    "        nn.init.xavier_uniform_(self.input_proj.weight)\n",
    "        nn.init.zeros_(self.input_proj.bias)\n",
    "        nn.init.xavier_uniform_(self.output_proj.weight)\n",
    "\n",
    "    def forward(self, hidden_state, target_ids=None):\n",
    "        B = hidden_state.size(0)\n",
    "        h0 = self.input_proj(hidden_state)\n",
    "        h0 = h0.unsqueeze(0).expand(self.gru.num_layers, -1, -1).contiguous()\n",
    "        x  = torch.zeros(B, h0.shape[-1], device=hidden_state.device,\n",
    "                         dtype=hidden_state.dtype)\n",
    "        h  = h0\n",
    "        logits_list = []\n",
    "        for step in range(self.num_draft_tokens):\n",
    "            out, h = self.gru(x.unsqueeze(1), h)\n",
    "            logits = self.output_proj(out.squeeze(1))\n",
    "            logits_list.append(logits)\n",
    "            if target_ids is not None:\n",
    "                x = self.token_embed(target_ids[:, step])\n",
    "            else:\n",
    "                x = self.token_embed(logits.argmax(dim=-1))\n",
    "        return torch.stack(logits_list, dim=1)  # [B, K, V]\n",
    "\n",
    "\n",
    "def compute_loss(draft_logits, target_ids):\n",
    "    \"\"\"Memory-efficient: compute loss one position at a time.\"\"\"\n",
    "    K = draft_logits.size(1)\n",
    "    loss = torch.tensor(0.0, device=draft_logits.device, dtype=torch.float32)\n",
    "    for k in range(K):\n",
    "        loss = loss + F.cross_entropy(\n",
    "            draft_logits[:, k, :].float(), target_ids[:, k], ignore_index=0\n",
    "        )\n",
    "    return loss / K\n",
    "\n",
    "print('Architecture defined.')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 4: Load tokenizer + base model (frozen on GPU)\n",
    "log.info(f'Loading tokenizer: {BASE_MODEL}')\n",
    "tokenizer = AutoTokenizer.from_pretrained(BASE_MODEL, trust_remote_code=True)\n",
    "if tokenizer.pad_token is None:\n",
    "    tokenizer.pad_token = tokenizer.eos_token\n",
    "vocab_size = len(tokenizer)\n",
    "log.info(f'Vocab size: {vocab_size}')\n",
    "\n",
    "log.info('Loading base model (bfloat16, frozen)...')\n",
    "base_model = AutoModelForCausalLM.from_pretrained(\n",
    "    BASE_MODEL,\n",
    "    torch_dtype=torch.bfloat16,\n",
    "    device_map='auto',\n",
    "    trust_remote_code=True,\n",
    ")\n",
    "base_model.eval()\n",
    "for p in base_model.parameters():\n",
    "    p.requires_grad_(False)\n",
    "\n",
    "hidden_size = base_model.config.hidden_size\n",
    "log.info(f'Base model loaded. Hidden size: {hidden_size}')\n",
    "log.info(f'VRAM used: {torch.cuda.memory_allocated()/1e9:.1f} GB')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 5: Dataset\n",
    "class ShareGPTDataset(Dataset):\n",
    "    def __init__(self, tokenizer, max_seq_len=512, max_samples=50_000):\n",
    "        log.info('Loading ShareGPT dataset...')\n",
    "        ds = load_dataset(\n",
    "            'anon8231489123/ShareGPT_Vicuna_unfiltered',\n",
    "            data_files='ShareGPT_V3_unfiltered_cleaned_split.json',\n",
    "            split='train',\n",
    "        )\n",
    "        self.samples = []\n",
    "        for row in ds.select(range(min(max_samples, len(ds)))):\n",
    "            text = ' '.join(t.get('value', '') for t in row.get('conversations', []))\n",
    "            if len(text) < 100:\n",
    "                continue\n",
    "            ids = tokenizer(\n",
    "                text, truncation=True, max_length=max_seq_len + 1,\n",
    "                return_tensors='pt'\n",
    "            ).input_ids.squeeze(0)\n",
    "            if len(ids) >= 8:\n",
    "                self.samples.append(ids)\n",
    "        log.info(f'Dataset: {len(self.samples)} samples')\n",
    "\n",
    "    def __len__(self): return len(self.samples)\n",
    "    def __getitem__(self, idx): return self.samples[idx]\n",
    "\n",
    "\n",
    "def collate_fn(batch):\n",
    "    max_len = max(x.size(0) for x in batch)\n",
    "    padded = torch.zeros(len(batch), max_len, dtype=torch.long)\n",
    "    for i, x in enumerate(batch): padded[i, :x.size(0)] = x\n",
    "    return padded\n",
    "\n",
    "\n",
    "dataset = ShareGPTDataset(tokenizer, MAX_SEQ_LEN, MAX_SAMPLES)\n",
    "loader  = DataLoader(dataset, batch_size=BATCH_SIZE, shuffle=True,\n",
    "                     collate_fn=collate_fn, drop_last=True, num_workers=2)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 6: Initialize draft head + optimizer\n",
    "draft_head = ReDrafterHead(\n",
    "    vocab_size=vocab_size,\n",
    "    hidden_size=hidden_size,\n",
    "    drafter_hidden=DRAFTER_HIDDEN,\n",
    "    num_layers=DRAFTER_LAYERS,\n",
    "    num_draft_tokens=NUM_DRAFT_TOKENS,\n",
    ").to(device).to(torch.bfloat16)\n",
    "\n",
    "n_params = sum(p.numel() for p in draft_head.parameters())\n",
    "log.info(f'Draft head: {n_params:,} params ({n_params/1e6:.1f}M)')\n",
    "\n",
    "# 8-bit Adam — halves optimizer memory vs standard AdamW\n",
    "try:\n",
    "    import bitsandbytes as bnb\n",
    "    optimizer = bnb.optim.AdamW8bit(\n",
    "        draft_head.parameters(), lr=LEARNING_RATE, weight_decay=WEIGHT_DECAY\n",
    "    )\n",
    "    log.info('Using 8-bit AdamW (bitsandbytes)')\n",
    "except Exception:\n",
    "    optimizer = AdamW(draft_head.parameters(), lr=LEARNING_RATE,\n",
    "                      weight_decay=WEIGHT_DECAY, betas=(0.9, 0.95))\n",
    "    log.info('Using standard AdamW')\n",
    "\n",
    "\n",
    "def get_lr(step):\n",
    "    if step < WARMUP_STEPS:\n",
    "        return LEARNING_RATE * step / max(WARMUP_STEPS, 1)\n",
    "    progress = (step - WARMUP_STEPS) / max(MAX_STEPS - WARMUP_STEPS, 1)\n",
    "    return LEARNING_RATE * 0.5 * (1 + math.cos(math.pi * progress))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 7: Training loop\n",
    "log.info('Starting training...')\n",
    "step = 0\n",
    "optimizer.zero_grad()\n",
    "t0 = time.time()\n",
    "new_lr = LEARNING_RATE\n",
    "\n",
    "while step < MAX_STEPS:\n",
    "    for batch in loader:\n",
    "        if step >= MAX_STEPS:\n",
    "            break\n",
    "\n",
    "        batch = batch.to(device)\n",
    "        seq_len = batch.size(1)\n",
    "        if seq_len < NUM_DRAFT_TOKENS + 2:\n",
    "            continue\n",
    "\n",
    "        max_start = seq_len - NUM_DRAFT_TOKENS - 1\n",
    "        start = torch.randint(1, max(2, max_start), (1,)).item()\n",
    "\n",
    "        context_ids = batch[:, :start]\n",
    "        target_ids  = batch[:, start:start + NUM_DRAFT_TOKENS]\n",
    "\n",
    "        # Base model forward (frozen, no grad)\n",
    "        with torch.no_grad():\n",
    "            outputs = base_model(\n",
    "                input_ids=context_ids,\n",
    "                output_hidden_states=True,\n",
    "                use_cache=False,\n",
    "            )\n",
    "            last_hidden = outputs.hidden_states[-1][:, -1, :]  # [B, H]\n",
    "\n",
    "        # Draft head forward\n",
    "        draft_logits = draft_head(last_hidden, target_ids=target_ids)\n",
    "        loss = compute_loss(draft_logits, target_ids) / GRAD_ACCUM\n",
    "        loss.backward()\n",
    "\n",
    "        if (step + 1) % GRAD_ACCUM == 0:\n",
    "            new_lr = get_lr(step)\n",
    "            for pg in optimizer.param_groups:\n",
    "                pg['lr'] = new_lr\n",
    "            optimizer.step()\n",
    "            optimizer.zero_grad()\n",
    "\n",
    "        step += 1\n",
    "\n",
    "        if step % LOG_EVERY == 0:\n",
    "            loss_val = loss.item() * GRAD_ACCUM\n",
    "            elapsed  = time.time() - t0\n",
    "            vram     = torch.cuda.memory_allocated() / 1e9\n",
    "            log.info(f'step={step}/{MAX_STEPS} | loss={loss_val:.4f} | '\n",
    "                     f'lr={new_lr:.2e} | vram={vram:.1f}GB | elapsed={elapsed:.0f}s')\n",
    "\n",
    "        if step % SAVE_EVERY == 0:\n",
    "            ckpt = f'{OUTPUT_DIR}/redrafter_qwen25-7b_step{step}.pt'\n",
    "            torch.save(draft_head.state_dict(), ckpt)\n",
    "            log.info(f'Saved checkpoint: {ckpt}')\n",
    "\n",
    "log.info('Training complete!')\n",
    "final_path = f'{OUTPUT_DIR}/redrafter_qwen25-7b_final.pt'\n",
    "torch.save(draft_head.state_dict(), final_path)\n",
    "log.info(f'Final weights saved: {final_path}')"
   ]
  },
  {

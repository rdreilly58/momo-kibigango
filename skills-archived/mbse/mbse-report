                            <th>Risk ID</th>
                            <th>Title</th>
                            <th>Probability</th>
                            <th>Impact</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
""".format(
        stats['coverage_pct'],
        stats['test_by_status'].get('passed', 0),
        stats['test_by_status'].get('in-progress', 0),
        len(risks)
    )
    
    for risk in sorted(risks, key=lambda r: r.get('id', '')):
        html += f"""
                        <tr>
                            <td><strong>{risk.get('id', '')}</strong></td>
                            <td>{risk.get('title', '')}</td>
                            <td>{risk.get('probability', '')}</td>
                            <td>{risk.get('impact', '')}</td>
                            <td><span class="status-badge">{risk.get('status', '')}</span></td>
                        </tr>
"""
    
    html += """
                    </tbody>
                </table>
            </div>
            
            <!-- Architecture Decisions Section -->

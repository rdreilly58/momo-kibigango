                </div>
                <div class="metric">
                    <div class="metric-value">{len(components)}</div>
                    <div class="metric-label">Architecture Components</div>
                </div>
                <div class="metric">
                    <div class="metric-value">{len(tests)}</div>
                    <div class="metric-label">Tests</div>
                </div>
                <div class="metric">
                    <div class="metric-value">{stats['coverage_pct']}%</div>
                    <div class="metric-label">Test Coverage</div>
                </div>
                <div class="metric">
                    <div class="metric-value">{len(risks)}</div>
                    <div class="metric-label">Risks Identified</div>
                </div>
                <div class="metric">
                    <div class="metric-value">{len(decisions)}</div>
                    <div class="metric-label">Architecture Decisions</div>
                </div>
            </div>
            
            <!-- Requirements Section -->
            <div class="section">
                <h2>✅ Requirements</h2>
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-value">{stats['req_by_status'].get('implemented', 0)}</div>
                        <div class="stat-label">Implemented</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-value">{stats['req_by_status'].get('in-progress', 0)}</div>
                        <div class="stat-label">In Progress</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-value">{stats['req_by_status'].get('proposed', 0)}</div>

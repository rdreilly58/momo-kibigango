#!/usr/bin/env python3
"""
mbse-report — Generate comprehensive HTML MBSE reports
Beautiful formatted reports with statistics and coverage analysis
"""

import sys
import json
from pathlib import Path
from datetime import datetime

try:
    import yaml
except ImportError:
    print("❌ PyYAML not installed")
    sys.exit(1)

def load_model(model_path):
    """Load YAML model"""
    path = Path(model_path)
    if not path.exists():
        print(f"❌ Model not found: {model_path}")
        sys.exit(1)
    
    with open(path, 'r') as f:
        return yaml.safe_load(f)

def generate_html_report(model, output_file=None):
    """Generate comprehensive HTML report"""
    
    system = model.get('system', {})
    requirements = {r['id']: r for r in model.get('requirements', [])}
    components = {c['id']: c for c in model.get('architecture', {}).get('components', [])}
    tests = {t['id']: t for t in model.get('tests', [])}
    risks = model.get('risks', [])
    decisions = model.get('decisions', [])
    
    # Calculate statistics
    stats = calculate_stats(requirements, components, tests, risks, decisions)
    
    # Build HTML
    html = build_html_template(system, requirements, components, tests, risks, decisions, stats)
    
    if output_file:
        with open(output_file, 'w') as f:
            f.write(html)
        print(f"✅ Report generated: {output_file}")
    else:
        print(html)
    
    return html

def calculate_stats(requirements, components, tests, risks, decisions):
    """Calculate report statistics"""
    
    # Requirements
    req_by_status = {}
    req_by_priority = {}
    for req in requirements.values():
        status = req.get('status', 'unknown')
        priority = req.get('priority', 'unknown')
        req_by_status[status] = req_by_status.get(status, 0) + 1
        req_by_priority[priority] = req_by_priority.get(priority, 0) + 1
    
    # Tests
    test_by_status = {}
    for test in tests.values():
        status = test.get('status', 'unknown')
        test_by_status[status] = test_by_status.get(status, 0) + 1
    
    # Coverage
    tested_reqs = sum(1 for r in requirements.keys() if any(r in t.get('verifies', []) for t in tests.values()))
    coverage_pct = int(100 * tested_reqs / len(requirements)) if requirements else 0
    
    # Risks
    risk_by_status = {}
    risk_by_impact = {}
    for risk in risks:
        status = risk.get('status', 'unknown')
        impact = risk.get('impact', 'unknown')
        risk_by_status[status] = risk_by_status.get(status, 0) + 1
        risk_by_impact[impact] = risk_by_impact.get(impact, 0) + 1
    
    return {
        'req_by_status': req_by_status,
        'req_by_priority': req_by_priority,
        'test_by_status': test_by_status,
        'tested_reqs': tested_reqs,
        'coverage_pct': coverage_pct,
        'risk_by_status': risk_by_status,
        'risk_by_impact': risk_by_impact
    }


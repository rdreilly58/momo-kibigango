"""
    
    return html

def main():
    if len(sys.argv) < 2:
        print("Usage: mbse-report <model.yaml> [--output file.html]")
        print("\nGenerates comprehensive HTML report with statistics and tables")
        sys.exit(1)
    
    model_path = sys.argv[1]
    output_file = None
    
    if "--output" in sys.argv:
        idx = sys.argv.index("--output")
        if idx + 1 < len(sys.argv):
            output_file = sys.argv[idx + 1]
    
    model = load_model(model_path)
    generate_html_report(model, output_file)

if __name__ == '__main__':
    main()
